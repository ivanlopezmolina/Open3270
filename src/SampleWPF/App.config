<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
            <section name="TerminalDemo.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
        </sectionGroup>
    </configSections>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0"/>
    </startup>
    <userSettings>
        <TerminalDemo.Properties.Settings>
            <!-- DangerousTlsCertificateValidationBypass: NEVER set true on untrusted networks. Disables TLS server certificate validation (MITM possible). Fix CA trust / hostname (CN/SAN) first. Search: TLS bypass, certificate validation bypass. -->
            <setting name="Hostname" serializeAs="String">
                <value />
            </setting>
            <setting name="UseSSL" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="DangerousTlsCertificateValidationBypass" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="TerminalType" serializeAs="String">
                <value>IBM-3278-2-E</value>
            </setting>
            <setting name="HostPort" serializeAs="String">
                <value>23</value>
            </setting>
        </TerminalDemo.Properties.Settings>
    </userSettings>
</configuration>
